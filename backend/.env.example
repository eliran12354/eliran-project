# PostgreSQL Connection
# Full connection string, e.g. from Render / pgAdmin:
#   postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/eliran
# Set to "false" only for a local Postgres without SSL. Managed providers (Render) need SSL.
DATABASE_SSL=true
# Optional: max connections in the pool (default 10)
# DATABASE_POOL_MAX=10

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Password reset links (no trailing slash). Defaults to CORS_ORIGIN if unset.
# APP_PUBLIC_URL=https://your-frontend.example.com

# Resend (https://resend.com) — password reset emails. In development, reset URL is logged if unset.
# RESEND_API_KEY=
# EMAIL_FROM=noreply@your-verified-domain.com

# JWT (required in env.ts)
# JWT_SECRET=
# JWT_EXPIRY=1h

# Internal cron / sync (POST /api/internal/sync/urban-renewal-notifications, header X-Cron-Secret)
# CRON_SECRET=
